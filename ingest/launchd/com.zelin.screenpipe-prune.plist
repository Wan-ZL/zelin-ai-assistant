<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.zelin.screenpipe-prune</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/YOURUSERNAME/.local/bin/screenpipe-prune-a11y.sh</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>4</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/Users/YOURUSERNAME/.screenpipe/prune-a11y.launchd.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/YOURUSERNAME/.screenpipe/prune-a11y.launchd.log</string>
</dict>
</plist>
