<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.zelin.screenpipe-process</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/YOURUSERNAME/.local/bin/process-screenpipe.sh</string>
    </array>

    <!-- Trigger when files appear in the unprocessed folder -->
    <key>WatchPaths</key>
    <array>
        <string>/Users/YOURUSERNAME/Documents/Obsidian Vault/1 - unprocessed</string>
    </array>

    <!-- Minimum 5 minutes between triggers (debounce) -->
    <key>ThrottleInterval</key>
    <integer>300</integer>

    <!-- Logging -->
    <key>StandardOutPath</key>
    <string>/tmp/screenpipe-process-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/screenpipe-process-stderr.log</string>
</dict>
</plist>
