<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  TEMPLATE: install.sh renders the /Users/YOURUSERNAME placeholders (python,
  repo root, $HOME) into ~/Library/LaunchAgents — do not load this file as-is.

  imessageradar — the §13 phone command surface over iMessage for users
  without Slack: polls the "message yourself" thread in
  ~/Library/Messages/chat.db (READ-ONLY, sqlite mode=ro) for approval commands
  (批准/拒绝/打回/验收 R-xxx), quick captures, and 👍/❤️ tapback approvals of
  🔔 notifications. Replies + mirrors are sent via osascript -> Messages.app.

  ONLY INSTALLED WHEN CONFIGURED: install.sh step 5 skips this plist unless
  config sets phone_channel: imessage (see docs/IMESSAGE_SETUP.md). Loaded
  without config it no-ops silently (skip_reason "disabled").

  FULL DISK ACCESS REQUIRED: chat.db lives under ~/Library/Messages, which is
  TCC-protected even for launchd user agents. Grant Full Disk Access to the
  python3 binary below (System Settings -> Privacy & Security -> Full Disk
  Access), or every pass no-ops with skip_reason db_open_failed. The first
  reply send may also pop an Automation consent for controlling Messages.app.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.zelin.aiassistant.imessageradar</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/YOURUSERNAME/miniconda3/bin/python3</string>
        <string>-m</string>
        <string>act.radar_imessage</string>
        <string>--once</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/YOURUSERNAME/Projects/zelin-ai-assistant</string>

    <!-- poll every 3 minutes -->
    <key>StartInterval</key>
    <integer>180</integer>
    <key>RunAtLoad</key>
    <true/>

    <key>EnvironmentVariables</key>
    <dict>
        <key>AIASSISTANT_HOME</key>
        <string>/Users/YOURUSERNAME/Projects/zelin-ai-assistant</string>
        <key>PATH</key>
        <string>/Users/YOURUSERNAME/.claude-bin:/opt/homebrew/bin:/opt/homebrew/sbin:/Users/YOURUSERNAME/miniconda3/bin:/Users/YOURUSERNAME/.local/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/YOURUSERNAME/Projects/zelin-ai-assistant/state/imessageradar.launchd.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/YOURUSERNAME/Projects/zelin-ai-assistant/state/imessageradar.launchd.log</string>
</dict>
</plist>
